// ============================================================
// schema.prisma — Donation Management System
// Updated: KhidmatRecord installment tracking
//   - amount        = total pledged (unchanged)
//   - receivedAmount = running total collected (new)
//   - KhidmatPayment = individual installment log (new model)
//   - New audit actions: KHIDMAT_PAYMENT_ADDED
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATOR
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  CHEQUE
}

// Status of a KhidmatRecord — drives WhatsApp message template
enum KhidmatStatus {
  COMPLETED // Fully paid / service complete
  PARTIAL // Partially paid — receivedAmount < amount
  RECORD_ONLY // Just recording — no payment yet
}

enum AuditAction {
  // ── Donation ──────────────────────────────
  DONATION_CREATED
  DONATION_EMAIL_SENT
  EMAIL_SENT
  EMAIL_RESENT
  EMAIL_FAILED
  WHATSAPP_SENT
  WHATSAPP_DELIVERED
  WHATSAPP_READ
  WHATSAPP_FAILED
  WHATSAPP_PENDING
  DONATION_UPDATED
  DONATION_DELETED
  DONATION_RESTORED
  WHATSAPP_SKIPPED

  // ── Auth / User ───────────────────────────
  OPERATOR_LOGIN
  ADMIN_LOGIN
  EMAIL_CHANGED
  USER_CREATED
  USER_UPDATED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED

  // ── Reports ───────────────────────────────
  PDF_EXPORTED

  // ── KhidmatRecord ─────────────────────────
  KHIDMAT_CREATED
  KHIDMAT_UPDATED
  KHIDMAT_DELETED
  KHIDMAT_RESTORED
  KHIDMAT_WHATSAPP_SENT
  KHIDMAT_WHATSAPP_FAILED
  KHIDMAT_WHATSAPP_SKIPPED
  KHIDMAT_PAYMENT_ADDED
  KHIDMAT_BULK_REMINDER_SENT
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String
  phone        String?
  role         Role    @default(OPERATOR)
  isActive     Boolean @default(true)

  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?

  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  donationsCreated Donation[]      @relation("OperatorDonations")
  donationsDeleted Donation[]      @relation("DeletedDonations")
  khidmatCreated   KhidmatRecord[] @relation("KhidmatOperator")
  khidmatDeleted   KhidmatRecord[] @relation("KhidmatDeletedBy")
  auditLogs        AuditLog[]

  @@map("users")
}

model Donation {
  id            String        @id @default(uuid())
  donorName     String
  donorEmail    String?
  donorPhone    String
  amount        Decimal       @db.Decimal(10, 2)
  purpose       String
  paymentMethod PaymentMethod
  notes         String?
  date          DateTime      @default(now())

  emailSent     Boolean   @default(false)
  emailSentAt   DateTime?
  emailError    String?
  receiptNumber String?

  whatsappSent      Boolean   @default(false)
  whatsappSentAt    DateTime?
  whatsappMessageId String?   @unique
  whatsappError     String?

  whatsappStatus          String?   @default("PENDING")
  whatsappStatusUpdatedAt DateTime?
  whatsappDeliveryDetails Json?
  whatsappReadAt          DateTime?
  templateUsed            String?
  templateType            String?

  operatorId String
  categoryId String?
  deletedBy  String?

  operator      User              @relation("OperatorDonations", fields: [operatorId], references: [id])
  deletedByUser User?             @relation("DeletedDonations", fields: [deletedBy], references: [id])
  category      DonationCategory? @relation(fields: [categoryId], references: [id])

  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([categoryId])
  @@index([deletedBy])
  @@map("donations")
}

model DonationCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?  @default("Tag")
  color       String?  @default("#3b82f6")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donations      Donation[]
  khidmatRecords KhidmatRecord[]

  @@map("donation_categories")
}

// ─────────────────────────────────────────────
// KhidmatRecord
// ─────────────────────────────────────────────
model KhidmatRecord {
  id String @id @default(uuid())

  // ── Person ────────────────────────────────
  name    String
  phone   String
  address String?

  // ── Financials ────────────────────────────
  // amount         = total pledged / committed
  // receivedAmount = sum of all installments collected so far
  // remainingAmount is always computed: amount - receivedAmount
  amount         Decimal @db.Decimal(10, 2)
  receivedAmount Decimal @default(0) @db.Decimal(10, 2)

  // ── Service ───────────────────────────────
  categoryId String
  status     KhidmatStatus @default(RECORD_ONLY)
  notes      String?

  // ── WhatsApp ──────────────────────────────
  whatsappSent            Boolean   @default(false)
  whatsappSentAt          DateTime?
  whatsappMessageId       String?   @unique
  whatsappError           String?
  whatsappStatus          String?   @default("PENDING")
  whatsappStatusUpdatedAt DateTime?

  // ── Soft-delete ───────────────────────────
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletionReason String?

  // ── Meta ──────────────────────────────────
  operatorId String
  deletedBy  String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── Relations ─────────────────────────────
  operator      User             @relation("KhidmatOperator", fields: [operatorId], references: [id])
  deletedByUser User?            @relation("KhidmatDeletedBy", fields: [deletedBy], references: [id])
  category      DonationCategory @relation(fields: [categoryId], references: [id])
  payments      KhidmatPayment[] // installment history

  @@index([operatorId])
  @@index([categoryId])
  @@index([status])
  @@index([deletedBy])
  @@map("khidmat_records")
}

// ─────────────────────────────────────────────
// KhidmatPayment
// Each row = one installment added to a KhidmatRecord.
// receivedAmount on the parent is always the SUM of these.
// ─────────────────────────────────────────────
model KhidmatPayment {
  id       String @id @default(uuid())
  recordId String

  amount Decimal  @db.Decimal(10, 2) // this installment amount
  notes  String? // optional note e.g. "received via bank"
  paidAt DateTime @default(now()) // when this payment was received

  createdAt DateTime @default(now())

  record KhidmatRecord @relation(fields: [recordId], references: [id])

  @@index([recordId])
  @@index([paidAt])
  @@map("khidmat_payments")
}

model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  entityType  String
  entityId    String?
  description String
  userRole    Role
  userId      String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  timestamp   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@map("audit_logs")
}
